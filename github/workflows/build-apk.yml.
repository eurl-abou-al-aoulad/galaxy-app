name: Build Android APK

on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: "20"

      - uses: actions/setup-java@v4
        with:
          distribution: "temurin"
          java-version: "17"

      - uses: android-actions/setup-android@v3

      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest

      - name: Create .env file
        run: |
          cat > .env << 'EOF'
          VITE_SUPABASE_PROJECT_ID="xmgacrgkjbifhxssqrsr"
          VITE_SUPABASE_URL="https://xmgacrgkjbifhxssqrsr.supabase.co"
          VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhtZ2FjcmdramJpZmh4c3NxcnNyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgwMTU0MDQsImV4cCI6MjA5MzU5MTQwNH0.u_LhmKRXEIUbIaufwLzb0lBD4VHpH1WJwzmy8ePA8MI"
          EOF

      - name: Install dependencies
        run: bun install

      - name: Build web
        run: bunx vite build

      - name: Add Android platform
        run: |
          if [ ! -d "android" ]; then bunx cap add android; fi

      - name: Sync Capacitor
        run: bunx cap sync android

      - name: Build APK
        working-directory: android
        run: |
          chmod +x gradlew
          ./gradlew assembleDebug --no-daemon

      - uses: actions/upload-artifact@v4
        with:
          name: galaxy-app-debug-apk
          path: android/app/build/outputs/apk/debug/app-debug.apk
