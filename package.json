{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "electron:start": "electron .",
    "electron:stage": "rm -rf electron-staging && mkdir -p electron-staging && cp -R electron dist electron-staging/ && printf '{\"name\":\"galaxy-accounting-software\",\"version\":\"1.0.0\",\"private\":true,\"type\":\"module\",\"main\":\"electron/main.cjs\"}' > electron-staging/package.json",
    "electron:pack:win": "electron-packager electron-staging Galaxy --platform=win32 --arch=x64 --out=electron-release --overwrite --asar --icon=electron/icon.ico",
    "electron:pack:mac": "electron-packager electron-staging Galaxy --platform=darwin --arch=x64 --out=electron-release --overwrite --asar --icon=electron/icon.icns",
    "electron:pack:linux": "electron-packager electron-staging Galaxy --platform=linux --arch=x64 --out=electron-release --overwrite --asar --icon=electron/icon.png",
    "verify:apk-project": "node scripts/verify-apk-project.cjs",
    "android:init": "npm run verify:apk-project && vite build && npx cap add android && npx cap sync android",
    "android:sync": "npm run verify:apk-project && vite build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "npm run verify:apk-project && vite build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "android:apk:win": "npm run verify:apk-project && vite build && npx cap sync android && cd android && gradlew.bat assembleDebug",
    "android:aab": "npm run verify:apk-project && vite build && npx cap sync android && cd android && ./gradlew bundleRelease",
    "android:aab:win": "npm run verify:apk-project && vite build && npx cap sync android && cd android && gradlew.bat bundleRelease"
  },
